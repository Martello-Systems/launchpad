// Launchpad: Prisma schema
// A single Waitlist table with self-referential referral attribution.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Waitlist {
  id           String    @id @default(cuid())
  email        String    @unique
  referralCode String    @unique
  position     Int
  verified     Boolean   @default(false)
  // Double-opt-in: a single-use token emailed at signup. It flips the entry
  // pending -> verified exactly once; it is retained (not cleared) afterwards so
  // a repeat confirmation is recognized and handled idempotently. See verifyEmail.
  verifyToken  String?   @unique
  // When the verifyToken stops being valid. A click after this is rejected as
  // expired; signing up again re-issues a fresh token. Null = no token / no TTL.
  verifyTokenExpiresAt DateTime?
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Self-referential attribution: who referred this signup.
  referredById String?
  referredBy   Waitlist?  @relation("Referrals", fields: [referredById], references: [id])
  referrals    Waitlist[] @relation("Referrals")

  @@index([referredById])
  @@index([position])
}

// Shared-store fixed-window rate limiter (opt-in via RATE_LIMIT_STORE=postgres).
// One row per limiter key (e.g. "signup:<ip>"). Unlike the default in-memory
// limiter, this survives restarts and is shared across instances/serverless
// lambdas, so the configured limit is enforced globally. See lib/rate-limit.ts.
model RateLimit {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}
